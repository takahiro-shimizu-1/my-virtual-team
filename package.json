{
  "name": "my-virtual-team",
  "private": true,
  "version": "0.1.0",
  "description": "shimizu virtual team runtime scaffold",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "bootstrap": "bash scripts/ensure-v4-ready.sh",
    "registry:build": "node scripts/build-registry.js",
    "graph:build": "bash scripts/rebuild-agent-graph.sh",
    "graph:context": "bash scripts/resolve-agent-context.sh",
    "runtime:migrate": "python3 runtime/src/cli/migrate.py",
    "runtime:task": "bash scripts/runtime-task.sh",
    "runtime:events": "python3 runtime/src/cli/events.py publish",
    "runtime:health": "python3 runtime/src/cli/health.py",
    "runtime:watch": "python3 runtime/src/cli/watch.py scan",
    "runtime:integrations": "python3 runtime/src/cli/integrations.py",
    "runtime:test": "python3 -m unittest discover -s runtime/tests -p 'test_*.py'",
    "validate:v4": "python3 scripts/validate-v4-team.py"
  }
}
